# Anthropic API (used directly for anthropic/ prefixed models)
ANTHROPIC_API_KEY=

# OpenAI-compatible API key (used for openai/ prefixed models via litellm)
# Also works with OpenRouter — set this to your OpenRouter key and use:
#   distill.model.url=https://openrouter.ai/api/v1
#   distill.model.name=openai/<model-name>
OPENAI_API_KEY=

# GitHub token (used by scrape_github.py for scraping PR issues)
GITHUB_TOKEN=
